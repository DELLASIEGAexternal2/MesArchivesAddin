<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="MailApp">

  <Id>b3b30f2-8c56-4028-9090-0198c5154a40</Id>
  <Version>1.0.0.6</Version>
  <ProviderName>Mes Archives Banque de France POC Bêta</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="POC_MesArchivesAddin"/>
  <Description DefaultValue="Archives et restauration des mails Outlook"/>

  <IconUrl DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/ModOp_Mes_ARCHIVES.pdf"/>

  <AppDomains>
    <AppDomain>https://dellasiegaexternal2.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/src/taskpane/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <FunctionFile resid="Commands.Url"/>

          <ExtensionPoint xsi:type="MessageReadCommandSurface">

            <OfficeTab id="TabDefault">

              <Group id="MesArchivesGroup">
                <Label resid="GroupLabel"/>

                <Control xsi:type="Button" id="archive2021">
                  <Label resid="archive2021Label"/>
                  <Supertip>
                    <Title resid="archive2021Label"/>
                    <Description resid="archive2021Desc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openArchive2021</FunctionName>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="archive2022">
                  <Label resid="archive2022Label"/>
                  <Supertip>
                    <Title resid="archive2022Label"/>
                    <Description resid="archive2022Desc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openArchive2022</FunctionName>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="archive2023">
                  <Label resid="archive2023Label"/>
                  <Supertip>
                    <Title resid="archive2023Label"/>
                    <Description resid="archive2023Desc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openArchive2023</FunctionName>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="archive2024">
                  <Label resid="archive2024Label"/>
                  <Supertip>
                    <Title resid="archive2024Label"/>
                    <Description resid="archive2024Desc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openArchive2024</FunctionName>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="modop">
                  <Label resid="modopLabel"/>
                  <Supertip>
                    <Title resid="modopLabel"/>
                    <Description resid="modopDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openModop</FunctionName>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="about">
                  <Label resid="aboutLabel"/>
                  <Supertip>
                    <Title resid="aboutLabel"/>
                    <Description resid="aboutDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openAbout</FunctionName>
                  </Action>
                </Control>

              </Group>

            </OfficeTab>

          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>

      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-80.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/src/commands/commands.html"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Mes Archives BdF_POC"/>
        <bt:String id="archive2021Label" DefaultValue="Archives 2021"/>
        <bt:String id="archive2022Label" DefaultValue="Archives 2022"/>
        <bt:String id="archive2023Label" DefaultValue="Archives 2023"/>
        <bt:String id="archive2024Label" DefaultValue="Archives 2024"/>
        <bt:String id="modopLabel" DefaultValue="Mode opératoire"/>
        <bt:String id="aboutLabel" DefaultValue="À propos"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="archive2021Desc" DefaultValue="Ouvrir les archives 2021"/>
        <bt:String id="archive2022Desc" DefaultValue="Ouvrir les archives 2022"/>
        <bt:String id="archive2023Desc" DefaultValue="Ouvrir les archives 2023"/>
        <bt:String id="archive2024Desc" DefaultValue="Ouvrir les archives 2024"/>
        <bt:String id="modopDesc" DefaultValue="Consulter le mode opératoire"/>
        <bt:String id="aboutDesc" DefaultValue="Informations sur l'application"/>
      </bt:LongStrings>

    </Resources>

  </VersionOverrides>

</OfficeApp>
