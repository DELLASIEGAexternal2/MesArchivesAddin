<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<!--
MANIFEST PRINCIPAL DE L'ADD-IN OUTLOOK
Ce fichier déclare l'add-in dans Outlook.

Il définit :
- l'identité de l'application
- les permissions Outlook
- les boutons dans le ruban
- la connexion SSO vers Microsoft Graph
-->

<OfficeApp
xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
xsi:type="MailApp">

<!--
IDENTIFIANT UNIQUE DE L'ADD-IN
Doit rester stable dans le temps.
-->
<Id>2b3b30f2-8c56-4028-9090-0198c5154a40</Id>

<!--
VERSION DE L'ADD-IN
Permet à Outlook de savoir si une mise à jour est disponible
-->
<Version>1.0.0.2</Version>

<!--
FOURNISSEUR DE L'APPLICATION
-->
<ProviderName>Mes_Archives_Banque_de_France</ProviderName>

<DefaultLocale>en-US</DefaultLocale>

<!--
NOM AFFICHÉ DANS OUTLOOK
-->
<DisplayName DefaultValue="Mes Archives"/>

<!--
DESCRIPTION UTILISÉE DANS L'ADMIN CENTER
-->
<Description DefaultValue="Archives et restauration des mails Outlook"/>

<!--
ICÔNES DE L'APPLICATION
-->
<IconUrl DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-64.png"/>

<HighResolutionIconUrl DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-128.png"/>

<!--
LIEN VERS DOCUMENTATION / MODE OPÉRATOIRE
-->
<SupportUrl DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/ModOp_Mes_ARCHIVES.pdf"/>

<!--
DOMAINE AUTORISÉ POUR L'ADD-IN
Important pour la sécurité
-->
<AppDomains>
<AppDomain>https://dellasiegaexternal2.github.io</AppDomain>
</AppDomains>

<!--
APPLICATION DESTINÉE À OUTLOOK
-->
<Hosts>
<Host Name="Mailbox"/>
</Hosts>

<!--
VERSION MINIMUM DES API OUTLOOK
-->
<Requirements>
<Sets>
<Set Name="Mailbox" MinVersion="1.8"/>
</Sets>
</Requirements>

<!--
PERMISSIONS OUTLOOK
ReadWriteMailbox permet :

- lecture mails
- modification mails
- déplacement mails
-->
<Permissions>ReadWriteMailbox</Permissions>

<!--
L'ADD-IN S'AFFICHE UNIQUEMENT
SUR LES EMAILS EN MODE LECTURE
-->
<Rule xsi:type="RuleCollection" Mode="Or">
<Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
</Rule>

<!--
VERSION AVANCÉE DU MANIFEST
Permet de définir les boutons du ruban Outlook
-->
<VersionOverrides
xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
xsi:type="VersionOverridesV1_0">

<Hosts>

<Host xsi:type="MailHost">

<DesktopFormFactor>

<!--
FICHIER JAVASCRIPT CONTENANT LES ACTIONS DES BOUTONS
-->
<FunctionFile resid="Commands.Url"/>

<!--
EXTENSION DU RUBAN OUTLOOK
-->
<ExtensionPoint xsi:type="MessageReadCommandSurface">

<OfficeTab id="TabDefault">

<!--
GROUPE DE BOUTONS
-->
<Group id="MesArchivesGroup">

<!--
NOM DU GROUPE DANS LE RUBAN
-->
<Label resid="GroupLabel"/>

<!--
ICÔNES UTILISÉES PAR LES BOUTONS
-->
<Icon>
<bt:Image size="16" resid="Icon.16x16"/>
<bt:Image size="32" resid="Icon.32x32"/>
<bt:Image size="80" resid="Icon.80x80"/>
</Icon>

<!--
BOUTON ARCHIVE 2021
-->
<Control xsi:type="Button" id="Archive2021">
<Label resid="Archive2021.Label"/>
<Action xsi:type="ExecuteFunction">
<FunctionName>openArchive2021</FunctionName>
</Action>
</Control>

<!--
BOUTON ARCHIVE 2022
-->
<Control xsi:type="Button" id="Archive2022">
<Label resid="Archive2022.Label"/>
<Action xsi:type="ExecuteFunction">
<FunctionName>openArchive2022</FunctionName>
</Action>
</Control>

<!--
BOUTON ARCHIVE 2023
-->
<Control xsi:type="Button" id="Archive2023">
<Label resid="Archive2023.Label"/>
<Action xsi:type="ExecuteFunction">
<FunctionName>openArchive2023</FunctionName>
</Action>
</Control>

<!--
BOUTON ARCHIVE 2024
-->
<Control xsi:type="Button" id="Archive2024">
<Label resid="Archive2024.Label"/>
<Action xsi:type="ExecuteFunction">
<FunctionName>openArchive2024</FunctionName>
</Action>
</Control>

<!--
OUVERTURE DU MODE OPÉRATOIRE
-->
<Control xsi:type="Button" id="Modop">
<Label resid="Modop.Label"/>
<Action xsi:type="ExecuteFunction">
<FunctionName>openModop</FunctionName>
</Action>
</Control>

<!--
FENÊTRE A PROPOS
-->
<Control xsi:type="Button" id="About">
<Label resid="About.Label"/>
<Action xsi:type="ExecuteFunction">
<FunctionName>openAbout</FunctionName>
</Action>
</Control>

</Group>

</OfficeTab>

</ExtensionPoint>

</DesktopFormFactor>

</Host>

</Hosts>

<!--
RESSOURCES UTILISÉES PAR LE MANIFEST
-->
<Resources>

<bt:Images>

<bt:Image id="Icon.16x16"
DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-16.png"/>

<bt:Image id="Icon.32x32"
DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-32.png"/>

<bt:Image id="Icon.80x80"
DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/assets/icon-80.png"/>

</bt:Images>

<bt:Urls>

<!--
FICHIER JAVASCRIPT DES ACTIONS
-->
<bt:Url id="Commands.Url"
DefaultValue="https://dellasiegaexternal2.github.io/MesArchivesAddin/src/commands/commands.html"/>

</bt:Urls>

<!--
TEXTES UTILISÉS PAR LE RUBAN
-->
<bt:ShortStrings>

<bt:String id="GroupLabel" DefaultValue="Mes Archives BdF"/>

<bt:String id="Archive2021.Label" DefaultValue="2021"/>
<bt:String id="Archive2022.Label" DefaultValue="2022"/>
<bt:String id="Archive2023.Label" DefaultValue="2023"/>
<bt:String id="Archive2024.Label" DefaultValue="2024"/>

<bt:String id="Modop.Label" DefaultValue="Modop"/>

<bt:String id="About.Label" DefaultValue="À propos"/>

</bt:ShortStrings>

</Resources>

<!--
CONFIGURATION SSO POUR MICROSOFT GRAPH
-->
<WebApplicationInfo>

<!--
ID DE L'APPLICATION ENTRA
-->
<Id>b15e0e32-132a-4ac3-a1c8-18b1550f6394</Id>

<!--
RESOURCE URI
-->
<Resource>api://b15e0e32-132a-4ac3-a1c8-18b1550f6394</Resource>

<!--
PERMISSIONS GRAPH
-->
<Scopes>

<Scope>User.Read</Scope>

<Scope>Mail.Read</Scope>

<Scope>Mail.ReadWrite</Scope>

</Scopes>

</WebApplicationInfo>

</VersionOverrides>

</OfficeApp>
